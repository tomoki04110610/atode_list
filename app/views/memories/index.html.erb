<div class="container mt-4">
  <h2 class="mb-4">あとで調べるリスト </h2>
    <% if @memory.errors.any? %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% @memory.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="card mb-4 shadow-sm">
      <div class="card-body">
        <%= form_with(model: @memory) do |f| %>
          <div class="row g-2">
            <div class="col">
              <%= f.text_field :content, class: "form-control", placeholder: "何を調べますか？（140文字以内）"  %>
            </div>
            <div class="col-auto">
              <%= f.submit "追加", class: "btn btn-primary" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <div class="list-group">
      <% @memories.each do |memory| %>
        <div class="list-group-item d-flex justify-content-between align-items-center mb-3 shadow-sm rounded border-0 bg-white p-3">
          <div class="me-auto">
            <div class="fw-bold text-dark mb-1"><%= memory.content %></div>
            <div class="text-muted small">
              <%= memory.created_at.strftime("%Y/%m/%d %H:%M") %>
            </div>
          </div>

          <div class="d-flex align-items-center gap-2">
            <%= button_to "解決！", memory_path(memory), method: :patch, 
                class: "btn btn-success btn-sm px-3 rounded-pill shadow-sm" %>

            <%= button_to "削除", memory_path(memory), method: :delete, 
            data: { turbo_confirm: "この項目を削除しますか？" }, 
            class: "btn btn-outline-danger btn-sm rounded-pill" %>
          </div>
        </div>
      <% end %>
    </div>
</div>