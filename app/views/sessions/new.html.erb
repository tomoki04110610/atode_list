<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="text-center mb-4">あとでリスト　ログイン</h2>

      <%= form_with url: login_path, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :nickname, "ニックネーム",class: "form-label" %>
          <%= f.text_field :nickname, class: "form-control", placeholder: "登録したニックネームを入力" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, "パスワード", class: "form-label" %>
          <%= f.password_field :password, class: "form-control" %>
        </div>

        <div class="d-grid mt-4">
          <%= f.submit "ログイン", class: "btn btn-primary btn-lg" %>
        </div>
      <% end %>

      <div class="mt-4 text-center">
        <%= link_to "初めての方（新規登録）はこちら", signup_path, class: "text-decoration-none" %>
      </div>
    </div>
  </div>
</div>