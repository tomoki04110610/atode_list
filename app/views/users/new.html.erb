<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="text-center mb-4">新規ユーザー登録</h2>
      <div class="alert alert-warning mb-4" role="alert">
        <h4 class="alert-heading">パスワードに関する重要なお知らせ</h4>
        <p>当アプリはメールアドレスを収集しないため、<strong>パスワードの再発行が一切できません</strong></p>
        <hr>
        <p class="mb-0">パスワードは忘れないよう、必ず安全な場所にメモを控えてください。</p>
      </div>

      <%= form_with model: @user do |f| %>
        <div class="mb-3">
          <%= f.label :nickname, "ニックネーム（3～15文字）",class: "form-label" %>
          <%= f.text_field :nickname, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, "パスワード（4～72文字）", class: "form-label" %>
          <%= f.password_field :password, class: "form-control" %>
        </div>

        <div class="mb-3">
          <%= f.label :password_confirmation, "パスワード（再入力）", class: "form-label" %>
          <%= f.password_field :password_confirmation, class: "form-control" %>
        </div>

        <div class="d-grid mt-4">
          <%= f.submit "同意して利用を開始する", class: "btn btn-success btn-lg" %>
        </div>
      <% end %>

      <div class="mt-3 text-center">
        <%= link_to "既にアカウントをお持ちの方（ログイン）", login_path, class: "text-decoration-none" %>
      </div>
    </div>
  </div>
</div>